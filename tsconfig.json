{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": false,
    "types": ["bun"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "@clog/core": ["./apps/clog/src/index.ts"],
      "@clog/types": ["./apps/types/index.ts"]
    }
  },
  "include": [
    "index.ts",
    "apps/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ]
}
