{
  "name": "clog",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/clog",
    "apps/types",
    "packages/vercel-ai",
    "packages/vercel-chat"
  ],
  "scripts": {
    "dev": "bun run index.ts",
    "start": "bun run index.ts",
    "lint": "oxlint lint --max-warnings=0",
    "typecheck": "bunx tsc --noEmit",
    "build": "bunx --bun bun build apps/clog/src/index.ts --outdir dist --target node",
    "ci": "bun run lint && bun run typecheck && bun run build",
    "check": "bun run ci"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.2"
  }
}
