{
  "name": "clog",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/clog",
    "apps/types",
    "apps/frontends/*"
  ],
  "scripts": {
    "dev": "bun run index.ts",
    "start": "bun run index.ts",
    "lint": "oxlint lint --max-warnings=0",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bunx tsc --noEmit",
    "build": "bunx --bun bun build apps/clog/src/index.ts --outdir dist --target bun",
    "ci": "bun run lint && bun run typecheck && bun run build",
    "check": "bun run ci"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxlint": "^1.57.0",
    "typescript": "^6.0.2"
  }
}
