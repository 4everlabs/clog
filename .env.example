# ===============================================
# CLOG ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# ===============================================

# ─────────────────────────────────────────────
# REQUIRED: AI (OpenRouter recommended)
# ─────────────────────────────────────────────
OPENROUTER_API_KEY="sk-or-..."
# Or use OpenAI directly
# OPENAI_API_KEY="sk-..."

# ─────────────────────────────────────────────
# REQUIRED: PostHog
# ─────────────────────────────────────────────
POSTHOG_CLAW_POSTHOG_HOST="https://us.posthog.com"
POSTHOG_CLAW_POSTHOG_PROJECT_ID="your-project-id"
POSTHOG_CLAW_POSTHOG_PERSONAL_API_KEY="phc_..."

# ─────────────────────────────────────────────
# VERCEL
# ─────────────────────────────────────────────
VERCEL_TOKEN="your-vercel-token"
VERCEL_TEAM_ID="your-team-id"  # Optional

# ─────────────────────────────────────────────
# GITHUB
# ─────────────────────────────────────────────
GITHUB_TOKEN="ghp_..."
GITHUB_ORG="your-org"  # Optional
GITHUB_REPO="your-repo"  # Optional

# ─────────────────────────────────────────────
# TELEGRAM (chat with agent)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
TELEGRAM_ALLOWED_CHATS=""

# ─────────────────────────────────────────────
# RUNTIME SETTINGS
# ─────────────────────────────────────────────
POSTHOG_CLAW_EXECUTION_MODE="propose"  # observe | propose | execute
POSTHOG_CLAW_MONITOR_INTERVAL_MS=60000
POSTHOG_CLAW_CHANNELS="telegram,web,cli"
POSTHOG_CLAW_SHELL_EXECUTE=true
POSTHOG_CLAW_CHAT_NOTIFY=true

# ─────────────────────────────────────────────
# INSTANCE
# ─────────────────────────────────────────────
POSTHOG_CLAW_INSTANCE_ID="personal-instance"
POSTHOG_CLAW_APP_NAME="clog"
PORT=3000

# ─────────────────────────────────────────────
# POSTHOG CAPABILITIES
# ─────────────────────────────────────────────
POSTHOG_CLAW_POSTHOG_READ_INSIGHTS=true
POSTHOG_CLAW_POSTHOG_READ_ERRORS=true
POSTHOG_CLAW_POSTHOG_READ_LOGS=false
POSTHOG_CLAW_POSTHOG_READ_FLAGS=false
POSTHOG_CLAW_POSTHOG_READ_EXPERIMENTS=false
POSTHOG_CLAW_POSTHOG_MANAGE_ENDPOINTS=false

# ─────────────────────────────────────────────
# ERROR MONITORING THRESHOLDS
# ─────────────────────────────────────────────
POSTHOG_CLAW_ERROR_LOOKBACK_MINUTES=30
POSTHOG_CLAW_ERROR_SPIKE_THRESHOLD=10
POSTHOG_CLAW_ERROR_SPIKE_MULTIPLIER=2
POSTHOG_CLAW_CRITICAL_ERROR_THRESHOLD=25
