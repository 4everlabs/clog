PORT=3000
POSTHOG_CLAW_APP_NAME=PostHog Claw
POSTHOG_CLAW_CHANNELS=slack,web,cli
POSTHOG_CLAW_EXECUTION_MODE=propose
POSTHOG_CLAW_MONITOR_INTERVAL_MS=60000
POSTHOG_CLAW_INSTANCE_ID=personal-instance
POSTHOG_CLAW_INSTANCE_ROOT=.runtime/instances/personal-instance
POSTHOG_CLAW_BRAIN_STORAGE_DIR=.runtime/instances/personal-instance/brain/storage
POSTHOG_CLAW_RUNTIME_DB_PATH=.runtime/instances/personal-instance/brain/storage/runtime.sqlite

POSTHOG_CLAW_POSTHOG_HOST=https://us.posthog.com
POSTHOG_CLAW_POSTHOG_PROJECT_ID=your_project_id
POSTHOG_CLAW_POSTHOG_PERSONAL_API_KEY=phx_your_project_scoped_personal_api_key
POSTHOG_CLAW_POSTHOG_PROJECT_API_KEY=
POSTHOG_CLAW_POSTHOG_FEATURE_FLAGS_SECURE_KEY=
POSTHOG_CLAW_POSTHOG_ENDPOINTS_DIR=posthog/endpoints
POSTHOG_CLAW_POSTHOG_CLI_BIN=posthog-cli
POSTHOG_CLAW_POSTHOG_CLI_TIMEOUT_MS=30000
POSTHOG_CLAW_POSTHOG_REQUEST_TIMEOUT_MS=10000

POSTHOG_CLAW_POSTHOG_READ_INSIGHTS=true
POSTHOG_CLAW_POSTHOG_READ_ERRORS=true
POSTHOG_CLAW_POSTHOG_READ_LOGS=false
POSTHOG_CLAW_POSTHOG_READ_FLAGS=false
POSTHOG_CLAW_POSTHOG_READ_EXPERIMENTS=false
POSTHOG_CLAW_POSTHOG_MANAGE_ENDPOINTS=false
POSTHOG_CLAW_POSTHOG_UPLOAD_SOURCEMAPS=false
POSTHOG_CLAW_POSTHOG_ENABLE_LOGS=false
POSTHOG_CLAW_POSTHOG_ENABLE_FLAGS=false
POSTHOG_CLAW_POSTHOG_ENABLE_EXPERIMENTS=false

POSTHOG_CLAW_POSTHOG_ERROR_LOOKBACK_MINUTES=30
POSTHOG_CLAW_POSTHOG_ERROR_SPIKE_THRESHOLD=10
POSTHOG_CLAW_POSTHOG_ERROR_SPIKE_MULTIPLIER=2
POSTHOG_CLAW_POSTHOG_CRITICAL_ERROR_THRESHOLD=25

POSTHOG_CLAW_POSTHOG_PRIMARY_INSIGHT_NAME=Checkout conversion
POSTHOG_CLAW_POSTHOG_PRIMARY_INSIGHT_QUERY=SELECT 0 AS current_value, 0 AS previous_value
POSTHOG_CLAW_POSTHOG_PRIMARY_INSIGHT_REGRESSION_THRESHOLD_PERCENT=20
POSTHOG_CLAW_POSTHOG_PRIMARY_INSIGHT_MIN_PREVIOUS_VALUE=10

POSTHOG_CLAW_POSTHOG_SECONDARY_INSIGHT_NAME=
POSTHOG_CLAW_POSTHOG_SECONDARY_INSIGHT_QUERY=
POSTHOG_CLAW_POSTHOG_SECONDARY_INSIGHT_REGRESSION_THRESHOLD_PERCENT=20
POSTHOG_CLAW_POSTHOG_SECONDARY_INSIGHT_MIN_PREVIOUS_VALUE=10

POSTHOG_CLAW_GITHUB_READ=true
POSTHOG_CLAW_GITHUB_PR=true
POSTHOG_CLAW_GITHUB_PUSH=true
POSTHOG_CLAW_VERCEL_DEPLOY=true
POSTHOG_CLAW_CHAT_NOTIFY=true
POSTHOG_CLAW_SHELL_EXECUTE=true
